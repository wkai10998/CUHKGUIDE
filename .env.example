SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
# SUPABASE_ANON_KEY=<your-anon-key>
# SUPABASE_COMMENTS_TABLE=comments
# SUPABASE_USERS_TABLE=users

# 智谱 API（服务端）
ZHIPU_API_KEY=<your-zhipu-api-key>
# ZHIPU_CHAT_MODEL=glm-4.7-flash
ZHIPU_EMBEDDING_MODEL=embedding-3

# RAG 配置（需与 docs/supabase_rag.sql 维度一致）
RAG_EMBEDDING_DIM=1024
# RAG_CHUNK_SIZE=420
# RAG_CHUNK_OVERLAP=80
# RAG_TOP_K=4
# RAG_MIN_SIMILARITY=0.45
# RAG_INCLUDE_APP_CONTENT=false
# RAG_INCLUDE_EXTERNAL_CONTENT=true
# RAG_KB_DIR=knowledge_base/raw

# Supabase RAG RPC 名称（默认无需改）
# SUPABASE_RAG_UPSERT_RPC=upsert_rag_chunks
# SUPABASE_RAG_MATCH_RPC=match_rag_chunks
